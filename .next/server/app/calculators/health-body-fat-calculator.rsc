m transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md","children":[["$","div",null,{"className":"flex items-start justify-between gap-3","children":[["$","div",null,{"children":[["$","div",null,{"className":"text-xs font-medium uppercase tracking-[0.2em] text-slate-400","children":"Health"}],["$","h3",null,{"className":"mt-2 text-base font-semibold text-slate-900","children":"Calorie Needs Calculator | Health"}]]}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-up-right mt-1 h-4 w-4 text-slate-400 transition group-hover:text-slate-900","aria-hidden":"true","children":[["$","path","1tivn9",{"d":"M7 7h10v10"}],["$","path","1vkiza",{"d":"M7 17 17 7"}],"$undefined"]}]]}],["$","p",null,{"className":"mt-3 text-sm leading-6 text-slate-600","children":"Quickly estimate calorie needs outcomes for health planning with a focused calorie needs workflow."}],["$","div",null,{"className":"mt-4 text-sm font-medium text-slate-900","children":"Open calculator"}]]}],["$","$L2","health-bmr-calculator",{"href":"/calculators/health-bmr-calculator","className":"group block rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md","children":[["$","div",null,{"className":"flex items-start justify-between gap-3","children":[["$","div",null,{"children":[["$","div",null,{"className":"text-xs font-medium uppercase tracking-[0.2em] text-slate-400","children":"Health"}],["$","h3",null,{"className":"mt-2 text-base font-semibold text-slate-900","children":"BMR Calculator | Health"}]]}],["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"roun